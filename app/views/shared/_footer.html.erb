<footer class="footer mt-auto">
  <div class="container-fluid">
    <div class="d-flex flex-column align-items-center">

      <span class="footer-brand fw-semibold">
        <%= image_tag 'footer_logo.png', class: "img-fluid mb-3", style: "height: 80px", alt: "forkcast logo" %>
      </span>

      <div class="footer-links text-center w-100 my-2">
        <% if current_user && current_user.weeks.any? %>
          <%= link_to "Home", week_path(current_user.weeks.last), class: "footer-link ps-0 pe-3" %>
        <% end %>
        <span class="text-muted">|</span>
        <%= link_to "About", about_path, class: "footer-link ps-0 pe-3" %>
        <span class="text-muted">|</span>
        <%= link_to "Contact", "#", class: "footer-link" %>
      </div>

      <div class="footer-meta mt-3">
        © 2026 - A collaborative student project.
      </div>

    </div>

  </div>
</footer>
