<footer class="footer mt-auto">
  <div class="container-fluid">
    <div class="d-flex flex-column align-items-center">

      <span class="footer-brand fw-semibold">
        <%= image_tag 'footer_logo.png', class: "img-fluid", style: "height: 160px", alt: "forkcast logo" %>
      </span>

      <div class="footer-links text-center w-100">
        <% if current_user && current_user.weeks.any? %>
          <%= link_to "Home", week_path(Week.current_week_for_user(current_user)), class: "navbar-brand ms-0 me-2" %>
        <% end %>
        <span class="text-muted">|</span>
        <%= link_to "About", about_path, class: "footer-link ms-2" %>
      </div>

      <div class="footer-meta mt-3">
        © 2026 - A collaborative student project.
      </div>

    </div>

  </div>
</footer>
