<nav class="navbar navbar-expand-sm navbar-lewagon <%= yield :navbar_class %>">
  <div class="container-fluid">
    <% if user_signed_in? && !Week.current_week_for_user(current_user).nil? %>
      <%= link_to week_path(Week.current_week_for_user(current_user)), class: "navbar-brand" do %>
        <%= image_tag "navbar_logo.png" %>
      <% end %>
    <% else %>
    <div class="navbar-brand">
      <%= image_tag "navbar_logo.png" %>
    </div>
    <% end %>


    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav me-auto">
        <% if user_signed_in? %>
          <li class="nav-item active">
            <% if Week.current_week_for_user(current_user).nil? %>
              <%= link_to "#", class: "nav-link" do %>
                <i class="fa-solid fa-calendar-week p-1"></i>
                Week Planner
              <% end %>
            <% else %>
              <%= link_to week_path(Week.current_week_for_user(current_user)), class: "nav-link" do %>
                <i class="fa-solid fa-calendar-week p-1"></i>
                Week Planner
              <% end %>
            <% end %>
          </li>
          <li class="nav-item">
           <% if current_user.last_week?%>
            <%= link_to week_shopping_items_path(current_user.weeks.last), class: "nav-link" do %>
              <i class="fa-solid fa-basket-shopping p-1"></i>
              Shopping list
            <% end %>
            <% else %>
              <%= link_to "#", class: "nav-link" do %>
                <i class="fa-solid fa-basket-shopping p-1"></i>
                No shopping list available
              <% end %>
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to favorites_path, class: "nav-link" do %>
              <i class="fa-solid fa-heart p-1"></i>
              Favorites
            <% end %>
          </li>
          <li class="nav-item dropdown">
            <a href="#" id="navbarDropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
              <%= image_tag "https://i.pinimg.com/736x/6c/00/45/6c0045a2e6500365c3384011e42359cf.jpg", class: "avatar", alt: "dropdown menu" %>
            </a>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
              <%= link_to "Settings", edit_user_registration_path, class: "dropdown-item" %>
              <%= link_to "Preferences", settings_path, class: "dropdown-item" %>
              <%= link_to "Log out", destroy_user_session_path, data: {turbo_method: :delete}, class: "dropdown-item" %>
            </div>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "Login", new_user_session_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
