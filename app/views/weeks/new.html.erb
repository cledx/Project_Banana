<div class="container d-flex flex-column align-items-center">
  <h1 class="mt-4">Let's plan our meals for the week</h1>
  <p>Select the portions you want for each day</p>
  <div data-controller="sortable" id="calendar">
  <%= week_calendar(number_of_weeks: 1, events: [], attribute: :date) do |date, day| %>
    <div class="calendar-day">
      <% if @week.id %>
        <div class="day-header d-flex justify-content-between align-items-center mb-2">
          <h5 class="m-0 day-number"><%= date.strftime("%e") %></h5>
        </div>
      <% end %>


      <% ["breakfast", "lunch", "dinner"].each do |category| %>
        <div class="meal-section mb-3">
          <div class="meal-header">
            <span><%= category.capitalize %></span>
          </div>
          <div class="portion-selector ms-4">
            <div class="d-flex align-items-center">
              <span class="text-muted me-2">
                <i class="fa-solid fa-bowl-food"></i>
              </span>
              <div class="d-flex align-items-center gap-1">
                <button class="btn-ghost btn-sm" type="button" id="decrementPortion">−</button>
                <span class="portion-display px-2" id="portionSize">0</span>
                <button class="btn-ghost btn-sm" type="button" id="incrementPortion">+</button>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%= simple_form_for @week, url: weeks_path do |f| %>
  <%= f.submit "Generate meals",
        class: "btn btn-primary mt-3",
        data: { turbo_submits_with: "<i class='fa-light fa-spinner fa-spin'></i>".html_safe } %>
<% end %>
