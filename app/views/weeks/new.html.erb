<div class="page-banner" style="height: 160px"></div>

<div class="container d-flex flex-column align-items-center" data-controller="days-template slider">
  <div class="w-100 mt-4 mb-1">
    <div class="text-center mx-auto">
      <h1 class="mb-1">Let's plan our meals for the week</h1>
      <p class="mb-4">Select the portions you want for each day</p>
    </div>
  </div>

  <div data-controller="sortable" id="calendar">
    <div class = "mb-4">

      <div class="d-flex w-100 justify-content-between align-items-center">
        <div class="tag-box">
          <div class="tag-box-title">
              Preferences and Allergies:
              <% unless @user.allergies.nil? %>
                <% @user.allergies.each do |allergy| %>
                  <span style="display: inline-block; background:#FFEFE2; color: #E76F51; border: 1.5px solid #ffebe6; border-radius: 18px; font-size: 0.82rem; padding: 2.5px 14px; margin: 2px 4px 2px 0; line-height: 1.5; font-weight: 500;">
                    <%= allergy %>
                  </span>
                <% end %>
              <% end %>
              <% unless @user.disease.nil? %>
                <% @user.disease.each do |disease| %>
                  <span style="display: inline-block; background:#FFEFE2; color: #E76F51; border: 1.5px solid #ffebe6; border-radius: 18px; font-size: 0.82rem; padding: 2.5px 14px; margin: 2px 4px 2px 0; line-height: 1.5; font-weight: 500;">
                    <%= disease %>
                  </span>
                <% end %>
              <% end %>
            <span style="display: inline-block; background:#FFEFE2; color: #333; border: 1.5px solid #ffebe6; border-radius: 18px; font-size: 0.82rem; padding: 2.5px 14px; margin: 6px 4px 2px 0; line-height: 1.5; font-weight: 500; cursor: pointer;">
              <i class="fa-solid fa-plus fa-sm"></i>
            </span>
          </div>
      </div>
        <div>
          <label for="familySizeInput" class="form-label" data-slider-target="sliderValue">
            <i class="fa-solid fa-utensils"></i>
            Portion Size:
          </label>
          <input
            type="number"
            class="form-control w-auto d-inline-block"
            min="1"
            max="10"
            step="1"
            value="1"
            id="familySizeInput"
            data-slider-target="value"
            data-action="input->slider#updateValue"
          >
        </div>
      </div>

    <%= week_calendar(number_of_weeks: 1, events: [], attribute: :date) do |date, day| %>
      <div class="calendar-day">
        <% ["breakfast", "lunch", "dinner"].each do |category| %>
          <div class="meal-wrapper">
            <div class="meal-section mb-3 tiny-card btn btn-outline-custom" data-category="<%= category.capitalize %>" data-day="<%= date.strftime('%A').downcase %>" data-action="click->slider#addButton" data-slider-target="display">
              <div class="meal-header m-0">
                <span><%= category.capitalize %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="d-flex justify-content-end">
  <div class="btn btn-accent btn-lg shadow-sm text-light mb-4" data-action="click->slider#generate">Generate Week</div>
    </div>
  </div>
</div>
