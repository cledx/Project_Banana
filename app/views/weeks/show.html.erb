<!-- Banner -->
<div class="page-banner">
  <div class="container">

    <div class="banner-inner">
      <h1 class="banner-title">
        Week Planner
      </h1>
      <p class="banner-subtitle">Check what you need to prepare!</p>
    </div>

  </div>
</div>

<div class="container">

<!-- Today Section -->
<% if @today.present? %>
  <div class="today-section my-4">

      <%= link_to week_day_path(@week, @today), class:"text-decoration-none" do %>
      <h2>
        Today
        <i class="fa-solid fa-chevron-right fa-xs"></i>
      </h2>
      <% end %>


    <div class="row">
      <% @today.dishes.each do |dish| %>
        <div class="col-md-4">
          <%= link_to dish_path(dish), class: "text-decoration-none" do %>
            <div class="card p-3 w-100 meal-card">
              <p class="meal-category"><%= dish.category.capitalize %></p>
              <h5 class="card-title"><%= dish.recipe.name %></h5>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

  </div>
<% end %>

<!-- Week Section -->

<div data-controller="sortable" id="calendar">
  <%= week_calendar(number_of_weeks: 2, events: @week.days, attribute: :date) do |date, day| %>

    <% day = day.first %>
    <% if day %>
      <%= link_to week_day_path(@week, day) do %>
        <h3><%= day.date.strftime("%e") %></h3>
      <% end %>
      <% ["breakfast", "lunch", "dinner"].each do |category| %>
        <p class="m-2"><%= category.capitalize %>:</p>
        <% dishes = day.dishes.select { |dish| dish.category == category } %>
        <div class="sortable-list" data-day_id="<%= day.id %>" data-category="<%= category %>">
          <% if dishes.any? %>
            <% dishes.each do |dish| %>
              <div class="card p-2 w-100" data-dish_id="<%= dish.id %>">
                <%= link_to dish_path(dish), class: "nav-link" do %>
                  <p class="d-flex justify-content-between align-items-center m-0 card-title truncate-text"><%= dish.recipe.name %><i class="fa-solid fa-user-group"> <%= dish.portions %></i></p>
                <% end %>
              </div>
            <% end %>

    <div class="calendar-day <%= 'today-highlight' if day&.date&.to_date == Date.current %>">

      <% if day %>

        <!-- Header  -->
        <div class="day-header d-flex justify-content-between align-items-center mb-2">
          <%= link_to week_day_path(@week, day) do %>
            <h5 class="m-0 day-number">
              <%= day.date.strftime("%e") %>
            </h5>
          <% end %>
        </div>

        <!-- Meal Section -->
        <% ["breakfast", "lunch", "dinner"].each do |category| %>

          <div class="meal-section mb-3">

            <div class="meal-header">
              <span><%= category.capitalize %></span>
            </div>

            <% dishes = day.dishes.select { |dish| dish.category == category } %>

            <div class="sortable-list"
                 data-day_id="<%= day.id %>"
                 data-category="<%= category %>">

              <% if dishes.any? %>

                <% dishes.each do |dish| %>
                  <div class="planner-card w-100 position-relative"
                    data-dish_id="<%= dish.id %>">

                    <%= link_to dish_path(dish),
                                class: "stretched-link text-decoration-none" do %>
                      <p class="m-0 card-title">
                        <%= dish.recipe.name %>
                      </p>
                    <% end %>

                  </div>
                <% end %>

              <% else %>

                <div class="empty-meal">
                  <span>No <%= category %> planned</span>
                </div>

              <% end %>

            </div>

          </div>

        <% end %>

      <% else %>

        <!-- Empty days -->
        <div class="calendar-day empty-day">
          <p class="text-muted small">No day created</p>
        </div>

      <% end %>
    <% end %>
  <% end %>

    </div>

  <% end %>

    <!-- Shopping list button -->
    <div class="mt-4 mb-4 d-flex justify-content-end">
      <%= link_to week_shopping_items_path(@week),
                  class: "btn btn-outline-primary btn-sm d-flex align-items-center gap-2" do %>

        <span>Shopping list</span>
        <i class="fa-solid fa-chevron-right fa-xs"></i>

      <% end %>
    </div>

</div>
</div>

<%= link_to "Shopping list", week_shopping_items_path(@week) %>
