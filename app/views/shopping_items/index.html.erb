<div class="shopping-wrapper">
<div class="container py-2">
  <div class="row">
    <div class="col-md-6 mx-auto">

      <!-- Back -->
      <div class="d-flex justify-content-between mb-1 p-1">
        <%= link_to "‹ Back to Week", week_path(@week), class: "btn btn-ghost-white" %>
      </div>

      <!-- Card -->
      <div class="card mb-4">
        <div class="card-body" data-controller="shopping-list">

          <div class="d-flex justify-content-between align-items-center mb-2 p-2">
            <h4 class="card-title mb-2 mt-2">
              <i class="fa-solid fa-cart-shopping fa-sm"></i>
              Shopping List
            </h4>

            <span class="badge <%= @items_remaining.positive? ? "bg-warning" : "bg-primary" %>" data-shopping-list-target="counter">
              <% if @items_remaining.positive? %>
                <%= @items_remaining %> remaining
              <% else %>
                Done
              <% end %>
            </span>
          </div>

          <ul class="list-unstyled mb-0">
            <% @shopping_items.sort_by { |item| item.ingredient.name }.each do |item| %>
              <li class="mb-2 pb-2 border-bottom border-light">

                <%= simple_form_for item do |f| %>
                  <div class="d-flex align-items-center justify-content-between border-bottom">

                    <div class="form-check d-flex align-items-center">

                      <label class="form-check d-flex align-items-center shopping-item-label p-2 ps-4 <%= 'text-decoration-line-through text-muted' if item.purchased %>">

                        <%= f.check_box :purchased,
                                        class: "form-check-input me-2",
                                        data: {action: "change->shopping-list#purchased", shopping_list_target: "checkboxes"} %>

                        <%= item.ingredient.name %> — <%= item.unit %>

                      </label>

                    </div>
                    <details>
                      <summary class="text-muted" style="cursor: pointer; font-size: 0.85rem;"></summary>
                      <ul class="mt-1">
                        <% item.dishes_with_ingredient.map { |dish| dish.recipe.name }.uniq.each do |name| %>
                          <li><%= name %></li>
                        <% end %>
                      </ul>
                    </details>

                <% end %>
              </li>
            <% end %>
          </ul>

        </div>
      </div>

    </div>
  </div>
</div>
</div>
