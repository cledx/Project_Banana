<div class="page-banner">
  <div class="container">
    <div class="banner-inner">
      <h1 class="banner-title">My Favorite Recipes</h1>
      <p class="banner-subtitle">Find your favorite recipes here!</p>
    </div>
  </div>
</div>

<div class="container">
  <% if @recipes.present? %>
    <div class="row mt-4">
      <% @recipes.each do |recipe| %>

      <div class="col-md-3 mb-4">
        <div class="card recipe-card recipe-card--favorites position-relative">

          <%= link_to toggle_favorites_path(recipe_id: recipe.id),
                      data: { turbo_method: :post },
                      class: "delete-dish-btn" do %>
            <i class="fa-solid fa-xmark fa-lg"></i>
          <% end %>

          <%= image_tag recipe.image_url, class: "img-fluid card-img-top" %>
          <div class="card-body">
            <h5 class="card-title"><%= recipe.name %></h5>

            <%= link_to "", recipe_path(recipe),
                  class: "stretched-link" %>

          </div>
        </div>
      </div>

      <% end %>
    </div>
  <% else %>
    <p>No favorite recipes yet.</p>
  <% end %>
</div>
