<div class="page-banner">
  <div class="container">
    <div class="banner-inner">
      <h1 class="banner-title">My Favorite Recipes</h1>
      <p class="banner-subtitle">Find your favorite recipes here!</p>
    </div>
  </div>
</div>

<div class="container my-4">
  <div class="d-flex justify-content-between mb-1 p-1">
    <%= link_to "‹ Back", request.referer, class: "btn btn-ghost" %>
  </div>
  <% if @recipes.present? %>
    <div class="row">
      <% @recipes.each do |recipe| %>

      <div class="col-md-3 mb-4" data-controller="favorites">
        <div class="card recipe-card recipe-card--favorites position-relative parent-element">

          <a data-action="click->favorites#delete" data-recipe-id="<%= recipe.id %>" class="delete-dish-btn">
            <i class="fa-solid fa-xmark fa-lg text-white"></i>
          </a>

          <% recipe_image = "recipe_images/#{recipe.name.downcase.gsub(' ', '_')}.png" %>
          <%= image_tag recipe_image, class: "img-fluid card-img-top", onerror: "this.src='/assets/flipcard_placeholder.jpg'" %>
          <div class="card-body">
            <h5 class="card-title"><%= recipe.name %></h5>

            <%= link_to "", recipe_path(recipe),
                  class: "stretched-link" %>

          </div>
        </div>
      </div>

      <% end %>
    </div>
  <% else %>
    <p>No favorite recipes yet.</p>
  <% end %>
</div>
