<div class="page-banner" style="height: 160px">
</div>

<div class="container mt-4">
  <div class="row">
    <div class="col-md-12 mx-auto">

      <!-- Back -->
      <div class="d-flex justify-content-between mb-1 p-1">
        <%= link_to "‹ Back", request.referer, class: "btn btn-ghost" %>
      </div>

      <div class="d-flex recipe-card mb-4">
        <div>
          <% if @recipe.image_url.present? %>
            <%= image_tag @recipe.image_url, class: "img-fluid card-img-top" %>
          <% else %>
            <%= image_tag "flipcard_placeholder.jpg", class: "img-fluid card-img-top" %>
          <% end %>
        </div>
        <div class="card-body position-relative" data-controller="favorites">
          <div class="d-flex justify-content-between align-items-start">
            <div class="flex-grow-1">
              <h1 class="card-title display-4 mb-2"><%= @recipe.name %></h1>
              <div class="mb-3">
                <span class="badge bg-warning">
                  <i class="fa-solid fa-stopwatch"></i> <%= @recipe.cooktime+@recipe.preptime %> mins
                </span>
                <span class="badge bg-primary mb-2">
                  <i class="fa-solid fa-utensils"></i> <%= @recipe.cuisine %>
                </span>
                <% @recipe.tags.each do |tag| %>
                  <span class="badge bg-secondary mb-2">
                    <i class="fa-regular fa-circle-check"></i> <%= tag %>
                  </span>
                <% end %>
              </div>
            </div>
            <div class="d-flex flex-column align-items-end">
              <a data-action="click->favorites#toggle" data-recipe-id="<%= @recipe.id %>" data-favorites-target="btns" class="p-1 mb-5">
                <i class="<%= current_user.favorited?(@recipe) ? 'fa-solid fa-heart' : 'fa-regular fa-heart' %> fa-lg"></i>
              </a>
            </div>
          </div>
            <div class="position-absolute bottom-0 start-0 p-3">
              <%= render "shared/portion_selector" %>
            </div>
        </div>
      </div>
      <div class="row align-items-stretch">
        <div class="col-4 d-flex">
          <%# ingredients %>
          <div class="card w-100">
            <div class="card-body">
              <h3 class="card-title h5 mb-3">
                <i class="fa-solid fa-basket-shopping"></i> Ingredients
              </h3>
              <ul class="list mb-0">
                <% @recipe.recipe_items.each do |recipe_item| %>
                  <li class="border-bottom border-light">
                    <p class="text-muted"
                          data-base-amount="<%= recipe_item.amount %>"
                          data-unit="<%= recipe_item.unit %>">
                      <%= recipe_item.amount %>
                      <%= recipe_item.unit %> -
                      <%= recipe_item.ingredient.name %>
                    </p>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
        <div class="col-8 d-flex">
          <%# instructions %>
          <div class="card w-100">
            <div class="card-body">
              <h3 class="card-title h5 mb-3">
                <i class="fa-solid fa-kitchen-set"></i> Instructions
              </h3>
              <div class="instructions-text">
                <%= raw(render_markdown(@recipe.instructions)) %>
              </div>
            </div>
          </div>
        </div>
      </div>


    </div>
  </div>
</div>
