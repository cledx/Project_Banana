<div class="container my-4">
  <div class="row mb-3">
    <div class="col-12">
      <div
        class="d-flex align-items-center border border-dark p-4"
        style="background-image: url(Placeholder.com); background-size: cover; background-position: center; min-height: 150px;"
      >
        <h1 class="m-0"><%= @recipe.name %></h1>
      </div>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-6 mb-2 mb-md-0">
      <div class="border border-dark p-3">
        <strong>Cooktime</strong>
        <div>
          <%= @recipe.cooktime/60 %> mins
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="border border-dark p-3">
        <strong>Cuisine</strong>
        <div>
          <%= @recipe.cuisine %>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-md-8 mb-3 mb-md-0">
      <div class="border border-dark p-3">
        <strong>Instructions</strong>
        <div class="mt-2">
          <%= simple_format(@recipe.instructions) %>
        </div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="border border-dark p-3">
        <div class="mb-3">
        <!-- This slider is just for show you my idea -->
        <!-- This will probably need to use turbo/stimulus to update the ingredients list -->
          <label for="portion_size" class="form-label">
            Portion Size  -  (2) [This doesn't actually work]
          </label>
          <input
            type="range"
            class="form-range"
            id="portion_size"
            name="portion_size"
            min="1"
            max="10"
            step="1"
            value="2"
          >
        </div>

        <strong>Ingredients</strong>
        <ul class="mt-2">
        <!-- The amount of each recipe here would be calcuated by multiplying the default amount by whatever the portion is above. We will need to either add an attribute to each recipe that is "default portion size" or just have them all be a default portion size of 2 (or any other number) and calculate based on that. -->
          <% @recipe.recipe_items.each do |recipe_item| %>
            <li><%= recipe_item.ingredient.name %> - <%= recipe_item.amount %> <%= recipe_item.unit %></li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <!-- The link was broken, so I removed it for now-->
  </div>
</div>
