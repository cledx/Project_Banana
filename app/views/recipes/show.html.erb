<div class="container mt-4">
  <div class="row">
    <div class="col-md-12 mx-auto">

      <!-- Back -->
      <div class="d-flex justify-content-between mb-1 p-1">
        <%= link_to "‹ Back", request.referer, class: "btn btn-ghost" %>
      </div>

      <div class="card mb-4">
        <div class="card-body">

          <div class="d-flex justify-content-between align-items-start">

            <div class="flex-grow-1">
              <h1 class="card-title display-4 mb-2"><%= @recipe.name %></h1>
              <div class="mb-3">
                <span class="badge bg-primary me-2">
                  <i class="fa-solid fa-stopwatch"></i> <%= @recipe.cooktime/60 %> mins
                </span>
                <span class="badge bg-secondary">
                  <i class="fa-solid fa-utensils"></i> <%= @recipe.cuisine %>
                </span>
              </div>
            </div>


            <div class="portion-selector ms-4">
              <div class="d-flex align-items-center">
                <span class="text-muted me-2">
                  <i class="fa-solid fa-bowl-food"></i> Portions:
                </span>
                <div class="d-flex align-items-center gap-1">
                  <button class="btn-ghost btn-sm" type="button" id="decrementPortion">−</button>
                  <span class="portion-display px-2" id="portionSize">2</span>
                  <button class="btn-ghost btn-sm" type="button" id="incrementPortion">+</button>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <h3 class="card-title h5 mb-3">
            <i class="fa-solid fa-basket-shopping"></i> Ingredients
          </h3>
          <ul class="list mb-0">
            <% @recipe.recipe_items.each do |recipe_item| %>
              <li class="mb-2 pb-2 border-bottom border-light">
                <p class="text-muted"
                      data-base-amount="<%= recipe_item.amount %>"
                      data-unit="<%= recipe_item.unit %>">
                   <%= recipe_item.amount %> <%= recipe_item.unit %> -
                  <%= recipe_item.ingredient.name %>
                </p>
              </li>
            <% end %>
          </ul>
        </div>
      </div>

      <div class="card mb-4">
        <div class="card-body">
          <h3 class="card-title h5 mb-3">
            <i class="fa-solid fa-kitchen-set"></i> Instructions
          </h3>
          <div class="instructions-text">
            <%= simple_format(@recipe.instructions) %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
