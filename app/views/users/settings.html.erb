  <h1>Get Started</h1>
  <h2>with a cuisine</h2>
</div>
<div class="d-flex align-items-center justify-content-around h-100">
    <%= link_to "Cuisine", "#", class: "btn btn-secondary" =%>
    <%= link_to "Cuisine", "#", class: "btn btn-secondary" =%>
    <%= link_to "Cuisine", "#", class: "btn btn-secondary" =%>
    <%= link_to "Cuisine", "#", class: "btn btn-secondary" =%>
    <%= link_to "Cuisine", "#", class: "btn btn-secondary" =%>
    <%= link_to "Cuisine", "#", class: "btn btn-secondary" =%>
</div>
<%# steps %>
<%= form_with model: @user, url: settings_path, method: :patch do |f| %>
  <div class="steps-wrapper">
    <div class="form-step" id="step-1" data-preferences-target="steps">
      <h2 class="mt-3 mb-2">Let's personalize your meals</h2>
      <div class="row">
        <% cuisines = ["French", "Italian", "Japanese", "Mexican", "Indian", "Thai",
                  "Chinese", "Mediterranean", "American", "Spanish"] %>
        <% cuisines.each_with_index do |cuisine, index| %>
          <div class="col-4 mb-3">
            <%= f.radio_button :cuisine, "#{cuisine}", class: "btn-check", id: "cuisine", data: {preferences_target: "cuisines"} %>
            <%= label_tag "#{cuisine}", cuisine, class: "btn btn-outline-primary w-100" do %>
              <%= "#{cuisine}" %>
            <% end %>
          </div>
        <% end %>
      </div>
      <div class="text-end">
        <button type="button" class="btn btn-primary next-step" data-action="click->preferences#next">
          Next
        </button>
      </div>
    </div>
  </div>
<% end %>
