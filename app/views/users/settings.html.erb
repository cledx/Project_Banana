<div class="d-flex align-items-center flex-column pt-2">
  <h1>Let's personalize your meals</h1>
</div>
<%# steps %>
<div class="col-4 border border-primary align-items-center mx-auto m-3 p-5" data-controller="preferences">
      <%# step 1 %>
  <%= form_with model: @user, url: settings_path, method: :patch do |f| %>
    <div class="form-step" id="step-1" data-preferences-target="steps">
      <h3>What cuisines do you like?</h3>
      <div class="row">
        <% cuisines = ["French", "Italian", "Japanese", "Mexican", "Indian", "Thai",
                  "Chinese", "Mediterranean", "American", "Spanish"] %>
        <% cuisines.each_with_index do |cuisine, index| %>
          <div class="col-4 mb-3">
          <%= f.check_box :preferred_cuisines, { class: "btn-check", id: "cuisine_#{cuisine}", include_hidden: false, data: { preferences_target: "cuisines", action: "change->preferences#limitCuisines" }, multiple: true, value: cuisine }, cuisine %>
            <%= label_tag "cuisine_#{cuisine}", cuisine, class: "btn btn-outline-primary w-100 text-truncate" %>
          </div>
        <% end %>
      </div>
      <div class="text-end">
        <button type="button" class="btn btn-primary next-step" data-action="click->preferences#next">
          Next
        </button>
      </div>
    </div>
  <%# step 2 %>
  <div class="form-step d-none" id="step-2" data-preferences-target="steps">
    <h3 class="mt-3 mb-2">Any ingredients you like?</h2>

    <%= f.select :preferred_ingredients,
          [],
          {},
          { class: "form-control", id: "ingredients-select", multiple: true } %>

    <div class="d-flex justify-content-between mt-3">
      <button type="button" class="btn btn-outline-primary" data-action="click->preferences#previous">Back</button>
      <button type="button" class="btn btn-primary" data-action="click->preferences#next">Next</button>
    </div>
  </div>
  <%# step 3 %>
  <div class="form-step d-none" id="step-3" data-preferences-target="steps">
    <h3 class="mt-3 mb-2">Any ingredients you <em>don't</em> like?</h2>

    <%= f.select :undesireable_ingredients,
          [],
          {},
          { class: "form-control", id: "dislike-ingredients", multiple: true } %>

    <div class="d-flex justify-content-between mt-3">
      <button type="button" class="btn btn-outline-primary" data-action="click->preferences#previous">Back</button>
      <button type="button" class="btn btn-primary" data-action="click->preferences#next">Next</button>
    </div>
  </div>
  <%# step 4 %>
  <div class="form-step d-none" id="step-4" data-preferences-target="steps">
    <h3>Do you have any food allergies?</h3>
    <div class="row">
      <% allergies = ["peanuts", "tree nuts", "shellfish", "dairy", "gluten", "soy", "eggs", "fish"] %>
      <% allergies.each_with_index do |allergy, index| %>
        <div class="col-4 mb-3">
        <%= f.check_box :allergies, { class: "btn-check", id: "allergy_#{allergy}", include_hidden: false, data: { preferences_target: "allergies" }, multiple: true, value: allergy }, allergy %>
          <%= label_tag "allergy_#{allergy}", allergy, class: "btn btn-outline-primary w-100 text-truncate" %>
        </div>
      <% end %>
    </div>
    <div class="d-flex justify-content-between mt-3">
      <button type="button" class="btn btn-outline-primary" data-action="click->preferences#previous">Back</button>
      <button type="button" class="btn btn-primary" data-action="click->preferences#next">Next</button>
    </div>
  </div>
    <%# step 4 %>
  <div class="form-step d-none" id="step-4" data-preferences-target="steps">
    <h3>Do you have any food allergies?</h3>
    <div class="row">
      <% allergies = ["peanuts", "tree nuts", "shellfish", "dairy", "gluten", "soy", "eggs", "fish"] %>
      <% allergies.each_with_index do |allergy, index| %>
        <div class="col-4 mb-3">
        <%= f.check_box :allergies, { class: "btn-check", id: "allergy_#{allergy}", include_hidden: false, data: { preferences_target: "allergies" }, multiple: true, value: allergy }, allergy %>
          <%= label_tag "allergy_#{allergy}", allergy, class: "btn btn-outline-primary w-100 text-truncate" %>
        </div>
      <% end %>
    </div>
    <div class="d-flex justify-content-between mt-3">
      <button type="button" class="btn btn-outline-primary" data-action="click->preferences#previous">Back</button>
      <button type="button" class="btn btn-primary" data-action="click->preferences#next">Next</button>
    </div>
  </div>
  <%# step 5 %>
  <div class="form-step d-none" id="step-2" data-preferences-target="steps">
    <h3 class="mt-3 mb-2">Any ingredients you like?</h2>

    <%= f.select :preferred_ingredients,
          [],
          {},
          { class: "form-control", id: "ingredients-select", multiple: true } %>

    <div class="d-flex justify-content-between mt-3">
      <button type="button" class="btn btn-outline-primary" data-action="click->preferences#previous">Back</button>
      <button type="button" class="btn btn-primary" data-action="click->preferences#next">Next</button>
    </div>
  </div>
  <% end %>
</div>
