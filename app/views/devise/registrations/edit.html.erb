<div class="auth-layout">
  <div>
    <%= link_to "‹ Back", :back, class:"btn btn-ghost" %>
    <div class="auth-card">
        <h2 class="mt-2 mb-2">Edit Account</h2>

        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
          <%= f.error_notification %>

          <div class="form-inputs">
            <%= f.input :email, required: true, autofocus: true %>

            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <p>Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
            <% end %>

            <%= f.input :password,
                        hint: "leave it blank if you don't want to change it",
                        required: false,
                        input_html: { autocomplete: "new-password" } %>
            <%= f.input :password_confirmation,
                        required: false,
                        input_html: { autocomplete: "new-password" } %>
            <%= f.input :current_password,
                        hint: "we need your current password to confirm your changes",
                        required: true,
                        input_html: { autocomplete: "current-password" } %>
          </div>

          <div class="form-actions">
            <%= f.button :submit, "Update", class: "btn btn-primary w-100" %>
          </div>
        <% end %>


      <div><%= button_to "Cancel my account", registration_path(resource_name), class:"btn btn-ghost w-100 mt-2", data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete %></div>
    </div>
  </div>
</div>
